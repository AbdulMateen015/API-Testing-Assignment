							"let updatedName = 'Updated ' + pm.variables.replaceIn('{{$randomProductName}}');",
							"let updatedPrice = Math.floor(Math.random() * 5000) + 500;",
							"let updatedYear = 2025;",
							"let updatedColor = pm.variables.replaceIn('{{$randomColor}}');",
							"",
							"pm.collectionVariables.set('updatedProductName', updatedName);",
							"pm.collectionVariables.set('updatedPrice', updatedPrice);",
							"pm.collectionVariables.set('updatedYear', updatedYear);",
							"pm.collectionVariables.set('updatedColor', updatedColor);",
							"",
							"console.log('Generated Update Data:');",
							"console.log('- Updated Name:', updatedName);",
							"console.log('- Updated Price:', updatedPrice);",
							"console.log('- Updated Year:', updatedYear);",
							"console.log('- Color:', updatedColor);",
							"console.log('Updating object ID:', pm.collectionVariables.get('createdObjectId'));"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Tests Script: Validate PUT update",
							"console.log('=== TEST SCRIPT ===');",
							"",
							"// Parse JSON Response",
							"let jsonData = pm.response.json();",
							"console.log('Updated Object Response:', JSON.stringify(jsonData, null, 2));",
							"",
							"// Log updated values",
							"console.log('Updated Values:');",
							"console.log('- ID:', jsonData.id);",
							"console.log('- New Name:', jsonData.name);",
							"console.log('- Updated At:', jsonData.updatedAt);",
							"",
							"// Chai Assertions",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Object name was updated', function () {",
							"    pm.expect(jsonData.name).to.equal(pm.collectionVariables.get('updatedProductName'));",
							"});",
							"",
							"pm.test('Response contains updatedAt timestamp', function () {",
							"    pm.expect(jsonData).to.have.property('updatedAt');",
							"});",

		{
			"name": "2. POST - Create New Object (Random Data)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Pre-request Script: Generate random data for request body",
							"console.log('=== PRE-REQUEST SCRIPT ===');",
							"",
							"// Generate random product data",
							"let randomProductName = pm.variables.replaceIn('{{$randomProductName}}');",
							"let randomPrice = Math.floor(Math.random() * 9000) + 100; // Random price 100-9099",
							"let randomYear = Math.floor(Math.random() * 5) + 2020; // 2020-2024",
							"let randomCPU = pm.variables.replaceIn('{{$randomProductAdjective}}') + ' Processor';",
							"let randomStorage = (Math.floor(Math.random() * 4) + 1) * 256 + ' GB';",
							"",
							"// Store in collection variables for use in request body",
							"pm.collectionVariables.set('randomProductName', randomProductName);",
							"pm.collectionVariables.set('randomPrice', randomPrice);",
							"pm.collectionVariables.set('randomYear', randomYear);",
							"pm.collectionVariables.set('randomCPU', randomCPU);",
							"pm.collectionVariables.set('randomStorage', randomStorage);",
							"",
							"console.log('Generated Random Data:');",
							"console.log('- Product Name:', randomProductName);",
							"console.log('- Price:', randomPrice);",
							"console.log('- Year:', randomYear);",
							"console.log('- CPU:', randomCPU);",
							"console.log('- Storage:', randomStorage);"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Tests Script: Validate creation and chain response data",
							"console.log('=== TEST SCRIPT ===');",
							"",
							"// Parse JSON Response",
							"let jsonData = pm.response.json();",
							"console.log('Created Object Response:', JSON.stringify(jsonData, null, 2));",
							"",
							"// Log specific values from response",
							"console.log('Created Object Details:');",
							"console.log('- ID:', jsonData.id);",
							"console.log('- Name:', jsonData.name);",
							"console.log('- Created At:', jsonData.createdAt);",
							"",
							"// Store created object ID for API chaining",
							"pm.collectionVariables.set('createdObjectId', jsonData.id);",
							"console.log('Stored createdObjectId for chaining:', jsonData.id);",
							"",
							"// Chai Assertions",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response contains id', function () {",
							"    pm.expect(jsonData).to.have.property('id');",
							"    pm.expect(jsonData.id).to.be.a('string');",
							"});",
							"",
							"pm.test('Response contains name matching request', function () {",
							"    pm.expect(jsonData.name).to.equal(pm.collectionVariables.get('randomProductName'));",
							"});",
							"",
							"pm.test('Response contains createdAt timestamp', function () {",
							"    pm.expect(jsonData).to.have.property('createdAt');",
							"});",
							"",
							"pm.test('Response data object exists', function () {",
							"    pm.expect(jsonData).to.have.property('data');",
							"    pm.expect(jsonData.data).to.be.an('object');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"{{randomProductName}}\",\n    \"data\": {\n        \"year\": {{randomYear}},\n        \"price\": {{randomPrice}},\n        \"CPU model\": \"{{randomCPU}}\",\n        \"Hard disk size\": \"{{randomStorage}}\"\n    }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/objects",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"objects"
					]
				},
				"description": "POST request to create a new object with randomly generated data. Demonstrates:\n- Pre-request script generating random values\n- Storing variables for use in request body\n- API chaining by storing created object ID"
			},
			"response": []
		},

	"item": [
		{
			"name": "1. GET - List All Objects",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Pre-request Script: Setting up variables before the request",
							"console.log('=== PRE-REQUEST SCRIPT ===');",
							"console.log('Starting GET request to fetch all objects...');",
							"",
							"// Store request timestamp",
							"pm.collectionVariables.set('requestTimestamp', new Date().toISOString());",
							"console.log('Request Timestamp:', pm.collectionVariables.get('requestTimestamp'));"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Tests Script: Parsing JSON and writing assertions",
							"console.log('=== TEST SCRIPT ===');",
							"",
							"// Parse JSON Response",
							"let jsonData = pm.response.json();",
							"console.log('Response received with', jsonData.length, 'objects');",
							"",
							"// Log first few objects",
							"if (jsonData.length > 0) {",
							"    console.log('First object:', JSON.stringify(jsonData[0]));",
							"    // Store first object ID for chaining",
							"    pm.collectionVariables.set('existingObjectId', jsonData[0].id);",
							"    console.log('Stored existingObjectId:', jsonData[0].id);",
							"}",
							"",
							"// Chai Assertions",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response is an array', function () {",
							"    pm.expect(jsonData).to.be.an('array');",
							"});",
							"",
							"pm.test('Response time is less than 5000ms', function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(5000);",
							"});",
							"",
							"pm.test('Content-Type is application/json', function () {",
							"    pm.response.to.have.header('Content-Type');",
							"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
